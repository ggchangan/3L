# 3L 交易系统 — Docker .dockerignore
# 排除不需要复制到镜像的文件

# Git
.git
.gitignore
.github/

# Python 环境
.venv
.venv.bak
__pycache__
*.pyc
*.pyo

# 环境配置（运行时通过 -e 传入）
.env
.env.*

# 前端构建产出（运行时从 build stage 复制，不追踪 node_modules）
frontend/node_modules/

# 运行时数据（通过 -v 挂载）
data/
private/
logs/

# 其他
.hermes/
.pytest_cache/
test_snapshots/
__pycache__/
.DS_Store
server.pid
*.log
