# 3L 交易系统 — .env 模板
# 复制为 .env 后修改密码
WWW_DIR=/home/ubuntu/www
DATA_DIR=/home/ubuntu/data/3l
PORT=8080
SERVER_HOST=127.0.0.1
LOG_LEVEL=INFO
LOG_DIR=/home/ubuntu/www/logs
AUTH_USER=admin
AUTH_PASS=改成你的密码

# 微信报警推送（WxPusher）
# 注册: https://wxpusher.zjiecode.com → 创建应用 → 获取 APP_TOKEN
# UID: 扫关注二维码后从用户管理获取
WXPUSHER_TOKEN=AT_你的Token
WXPUSHER_UID=UID_你的UID
