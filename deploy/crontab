# 3L 交易系统 — 定时任务配置
# 安装: crontab deploy/crontab
# 查看: crontab -l

# ── 数据更新 ────────────────────────────
# 交易日6:00拉上一个交易日数据（同花顺数据次日才补齐）
0 6 * * 1-5 cd /home/ubuntu/3l-server/server && TQDM_DISABLE=1 /home/ubuntu/3l-server/.venv/bin/python3 -m backend.core.update_stock_data >> /home/ubuntu/3l-server/logs/update.log 2>&1

# 6:30 数据源验证
30 6 * * 1-5 cd /home/ubuntu/3l-server && bash server/scripts/run_verify.sh >> /home/ubuntu/3l-server/logs/verify.log 2>&1

# ── 备份 ────────────────────────────────
# 每日凌晨3点全量备份
0 3 * * * cd /home/ubuntu/3l-server && bash deploy/backup.sh >> /home/ubuntu/3l-server/logs/backup.log 2>&1

# ── 计划追踪 ────────────────────────────
# 22:00 计算操作计划追踪
0 22 * * 1-5 cd /home/ubuntu/3l-server/server && TQDM_DISABLE=1 /home/ubuntu/3l-server/.venv/bin/python3 -c "import sys,os; sys.path.insert(0,'.'); os.environ['DATA_DIR']='/home/ubuntu/data/3l'; from backend.services.plan_tracking_service import compute_tracking; r=compute_tracking(); print(f'Plan tracking: {r[\"summary\"][\"total_plans\"]}条, {r[\"summary\"][\"success_rate\"]}%')" >> /home/ubuntu/3l-server/logs/plan_tracking.log 2>&1
